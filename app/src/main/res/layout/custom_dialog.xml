<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="16dp"
    android:fadeScrollbars="false"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题栏 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/customTitleTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="🍥🍬 V+ GAME MENU"
                android:textColor="@color/game_menu_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCrownToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="2dp"
                android:text="@string/layout_custom_dialog_text_c9831"
                android:textColor="@color/theme_pink_primary"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:drawablePadding="4dp"
                app:drawableStartCompat="@drawable/ic_super_crown" />

        </RelativeLayout>

        <!-- 快捷按钮区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <!-- 第一行按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp"
                android:weightSum="3">

                <Button
                    android:id="@+id/btnWin"
                    style="@style/GameMenuButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="2dp"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_btn_win"
                    android:text="WIN" />

                <Button
                    android:id="@+id/btnEsc"
                    style="@style/GameMenuButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_btn_esc"
                    android:text="ESC" />

                <Button
                    android:id="@+id/btnHDR"
                    style="@style/GameMenuButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_btn_hdr"
                    android:text="HDR" />
            </LinearLayout>

            <!-- 第二行按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <Button
                    android:id="@+id/btnMic"
                    style="@style/GameMenuButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="2dp"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_mic_gm"
                    android:text="Mic" />

                <Button
                    android:id="@+id/btnSleep"
                    style="@style/GameMenuButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_btn_sleep"
                    android:text="@string/layout_custom_dialog_text_6d521" />

                <Button
                    android:id="@+id/btnQuit"
                    style="@style/GameMenuButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_btn_quit"
                    android:text="@string/layout_custom_dialog_text_c3992" />
            </LinearLayout>

        </LinearLayout>

        <!-- 菜单列表区域 (垂直堆叠) -->
        <LinearLayout
            android:id="@+id/menuListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical">

            <!-- 普通菜单 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <com.limelight.utils.NonScrollableListView
                    android:id="@+id/gameMenuList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:divider="@null"
                    android:dividerHeight="1dp"
                    android:fadeScrollbars="false"
                    android:scrollbars="vertical" />

            </LinearLayout>

            <!-- 超级菜单区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 特殊按键卡片 -->
                <LinearLayout
                    android:id="@+id/customKeysCardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:background="@drawable/game_menu_bitrate_bg"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:text="@string/layout_custom_dialog_text_f090a"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/game_menu_text_primary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingLeft="16dp"
                        android:paddingTop="8dp" />

                    <!-- 列表容器 -->
                    <LinearLayout
                        android:id="@+id/customKeysListLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

                <!-- 码率调整区域 -->
                <LinearLayout
                    android:id="@+id/bitrateAdjustmentContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/game_menu_bitrate_bg"
                    android:padding="8dp"
                    android:layout_marginBottom="8dp">

                    <!-- 码率调整标题 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/layout_custom_dialog_text_cf458"
                            android:textColor="@color/game_menu_text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:drawableStart="@drawable/ic_btn_bitrate"
                            android:drawablePadding="4dp"
                            android:gravity="center_vertical" />

                        <ImageView
                            android:id="@+id/bitrateTipIcon"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_info"
                            android:layout_marginStart="6dp"
                            android:layout_gravity="center_vertical"
                            android:contentDescription="@string/layout_custom_dialog_cd_99c74"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?android:attr/selectableItemBackgroundBorderless" />

                        <TextView
                            android:id="@+id/currentBitrateText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/layout_custom_dialog_text_6b362"
                            android:textColor="@color/theme_pink_primary"
                            android:textSize="11sp"
                            android:gravity="end"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <!-- 码率滑动条 -->
                    <SeekBar
                        android:id="@+id/bitrateSeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="1995"
                        android:progress="95"
                        android:progressTint="@color/theme_pink_primary"
                        android:thumbTint="@color/theme_pink_primary"
                        android:splitTrack="false"
                        android:layout_marginBottom="4dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                    <!-- 码率值显示 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.5"
                            android:textColor="@color/game_menu_text_secondary"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/bitrateValueText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="10 Mbps"
                            android:textColor="@color/theme_pink_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="200"
                            android:textColor="@color/game_menu_text_secondary"
                            android:textSize="10sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 陀螺仪控制卡片 -->
                <LinearLayout
                    android:id="@+id/gyroAdjustmentContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/game_menu_bitrate_bg"
                    android:padding="8dp"
                    android:layout_marginBottom="8dp">

                    <!-- 标题 + 开关按钮 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/layout_custom_dialog_text_90bba"
                            android:textColor="@color/game_menu_text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:drawableStart="@drawable/ic_btn_gyro"
                            android:drawablePadding="4dp"
                            android:gravity="center_vertical" />

                        <TextView
                            android:id="@+id/gyroStatusText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Off"
                            android:textColor="@color/theme_pink_primary"
                            android:textSize="11sp"
                            android:gravity="end" />

                        <Switch
                            android:id="@+id/gyroToggleSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textOn=""
                            android:textOff=""/>
                    </LinearLayout>

                    <!-- 详细设置 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/gyroActivationKeyContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:text="@string/gyro_activation_method"
                                android:textColor="@color/game_menu_text_primary"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/gyroActivationKeyText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LT (L2)"
                                android:textColor="@color/theme_pink_primary"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/gyroInvertXSwitchContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:text="@string/gyro_invert_x_axis"
                                android:textColor="@color/game_menu_text_primary"
                                android:textSize="11sp" />

                            <Switch
                                android:id="@+id/gyroInvertXSwitch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="false"
                                android:text=""
                                android:textOff=""
                                android:textOn="" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/gyroInvertYSwitchContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:text="@string/gyro_invert_y_axis"
                                android:textColor="@color/game_menu_text_primary"
                                android:textSize="11sp" />

                            <Switch
                                android:id="@+id/gyroInvertYSwitch"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="false"
                                android:text=""
                                android:textOff=""
                                android:textOn="" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 灵敏度滑动条 -->
                    <SeekBar
                        android:id="@+id/gyroSensitivitySeekBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="30"
                        android:progress="18"
                        android:progressTint="@color/theme_pink_primary"
                        android:thumbTint="@color/theme_pink_primary"
                        android:splitTrack="false"
                        android:layout_marginBottom="4dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                    <!-- 灵敏度值显示 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.5x"
                            android:textColor="@color/game_menu_text_secondary"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/gyroSensitivityValueText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/gyro_sensitivity_format"
                            android:textColor="@color/theme_pink_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3.0x"
                            android:textColor="@color/game_menu_text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>



                <!-- 超级菜单列表 -->
                <com.limelight.utils.NonScrollableListView
                    android:id="@+id/superMenuList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:divider="@null"
                    android:dividerHeight="1dp"
                    android:fadeScrollbars="false"
                    android:scrollbars="vertical" />

            </LinearLayout>

        </LinearLayout>

        <!-- App名字显示区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/appNameTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Moonlight"
                android:textColor="@color/theme_pink_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="2dp" />


            <ImageView
                android:id="@+id/cardEditorButton"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/ic_menu_edit"
                android:contentDescription="Edit visible cards" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>